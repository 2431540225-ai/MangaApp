<resources>
    <!--  BASE THEME (Light)  -->
    <style name="Base.Theme.MangaApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <!--  Window  -->
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:statusBarColor">@color/light_surface</item>
        <item name="android:navigationBarColor">@color/light_bottom_nav</item>
        <item name="android:windowLightStatusBar">true</item>
        <!--  Text  -->
        <item name="android:textColorPrimary">@color/light_text_primary</item>
        <item name="android:textColorSecondary">@color/light_text_secondary</item>
    </style>
    <style name="Theme.MangaApp" parent="Base.Theme.MangaApp"/>
    <!--  DARK THEME override  -->
    <style name="Theme.MangaApp.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@color/dark_surface</item>
        <item name="android:navigationBarColor">@color/dark_bottom_nav</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
    </style>
    <!--  Splash Theme  -->
    <style name="Theme.MangaApp.Splash" parent="Theme.MangaApp">
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
    </style>
    <!--  Bottom Navigation  -->
    <style name="BottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/light_bottom_nav</item>
        <item name="itemIconTint">@drawable/bottom_nav_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
</resources>