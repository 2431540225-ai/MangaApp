<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.Theme.MangaApp" parent="Theme.MaterialComponents.NoActionBar">

        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/primary_light</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <item name="android:colorBackground">@color/color_background</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="colorOnBackground">@color/color_text_primary</item>

        <!-- Tắt elevation overlay để card hiện bóng đổ đúng -->
        <item name="elevationOverlayEnabled">false</item>

        <item name="android:textColorPrimary">@color/color_text_primary</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
        <item name="android:textColorHint">@color/color_text_secondary</item>

        <item name="colorControlActivated">@color/primary</item>
        <item name="colorControlNormal">@color/color_text_secondary</item>
        <item name="colorControlHighlight">@color/color_ripple</item>

        <item name="tabStyle">@style/PillTabStyle</item>

    </style>

    <style name="Theme.MangaApp.Dark" parent="Base.Theme.MangaApp">
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle.Dark</item>
    </style>

    <style name="Theme.MangaApp.Light" parent="Base.Theme.MangaApp">
        <item name="android:navigationBarColor">@color/light_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle.Light</item>
    </style>

    <style name="Theme.MangaApp" parent="Theme.MangaApp.Dark" />

    <style name="Theme.MangaApp.Splash" parent="Theme.MangaApp.Dark">
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
    </style>

    <!-- ══ Bottom Navigation ═══════════════════════════════════════════════ -->

    <style name="BottomNavStyle.Dark" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@drawable/bg_floating_dock</item>
        <item name="itemIconTint">@drawable/bottom_nav_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_selector</item>
        <item name="itemRippleColor">@color/dark_ripple</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemIconSize">24dp</item>
        <item name="itemActiveIndicatorStyle">@style/BottomNavIndicator</item>
    </style>

    <style name="BottomNavStyle.Light" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@drawable/bg_floating_dock</item>
        <item name="itemIconTint">@drawable/bottom_nav_selector</item>
        <item name="itemTextColor">@drawable/bottom_nav_selector</item>
        <item name="itemRippleColor">@color/light_ripple</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemIconSize">24dp</item>
        <item name="itemActiveIndicatorStyle">@style/BottomNavIndicator</item>
    </style>

    <style name="BottomNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/violet_muted</item>
        <item name="shapeAppearance">@style/ShapeAppearance.BottomNavIndicator</item>
    </style>

    <style name="ShapeAppearance.BottomNavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ══ Tab (Pill Style) ══════════════════════════════════════════════════ -->

    <style name="PillTabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicatorHeight">0dp</item>
        <item name="tabIndicatorColor">@android:color/transparent</item>
        <item name="tabSelectedTextColor">@color/white</item>
        <item name="tabTextColor">@color/dark_text_secondary</item>
        <item name="tabTextAppearance">@style/PillTabTextAppearance</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabPaddingStart">4dp</item>
        <item name="tabPaddingEnd">4dp</item>
        <item name="tabMinWidth">0dp</item>
        <item name="tabMaxWidth">0dp</item>
    </style>

    <style name="PillTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- Tab với underline indicator (Favorites) -->
    <style name="UnderlineTabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/color_text_secondary</item>
        <item name="tabTextAppearance">@style/UnderlineTabTextAppearance</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabGravity">fill</item>
        <item name="tabMode">fixed</item>
        <item name="android:background">@color/color_surface</item>
    </style>

    <style name="UnderlineTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">15sp</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- ══ Cards & Badges ═══════════════════════════════════════════════════ -->

    <style name="BadgeStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
    </style>

    <style name="RoundedCornersImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/color_glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ══ Chips ══════════════════════════════════════════════════════════ -->

    <style name="ChipActive" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="chipBackgroundColor">@color/primary</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="ChipInactive" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/dark_text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="chipBackgroundColor">@color/dark_surface</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeColor">@color/violet_border</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- ══ Buttons ═════════════════════════════════════════════════════════ -->

    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- ══ Profile Toolbar ══════════════════════════════════════════════════ -->
    <style name="TextAppearance.Profile.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>