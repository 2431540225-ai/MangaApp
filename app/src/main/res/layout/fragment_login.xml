<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="vertical"
    android:scrollbarThumbVertical="@drawable/bg_button_gradient"
    android:scrollbarSize="4dp"
    android:fadeScrollbars="true"
    android:scrollbarFadeDuration="1000">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Decorative top-right circle -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-40dp"
            android:layout_marginEnd="-40dp"
            android:background="@drawable/bg_logo_glow"
            android:alpha="0.4" />

        <!-- Decorative bottom-left circle -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="60dp"
            android:layout_marginStart="-30dp"
            android:background="@drawable/bg_logo_glow"
            android:alpha="0.25" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="32dp">

            <!-- ═══════════ Logo Section ═══════════ -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_logo_glow" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/truyenhay_logo"
                    android:contentDescription="Logo" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Truyện Hay"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chào mừng bạn trở lại!"
                android:textSize="14sp"
                android:textColor="#80FFFFFF"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="40dp" />

            <!-- ═══════════ Error Message ═══════════ -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#FF8A80"
                android:background="@drawable/bg_error_message"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:drawablePadding="8dp" />

            <!-- ═══════════ Username Field ═══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingHorizontal="18dp"
                android:layout_marginBottom="14dp"
                android:focusableInTouchMode="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_nav_profile"
                    android:layout_marginEnd="14dp"
                    android:alpha="0.6"
                    android:tint="#B0B0D0"
                    android:contentDescription="User icon" />

                <EditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Tên đăng nhập"
                    android:textColorHint="#888888"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionNext" />
            </LinearLayout>

            <!-- ═══════════ Password Field ═══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingHorizontal="18dp"
                android:layout_marginBottom="8dp"
                android:focusableInTouchMode="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    android:layout_marginEnd="14dp"
                    android:alpha="0.6"
                    android:tint="#B0B0D0"
                    android:contentDescription="Lock icon" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Mật khẩu"
                    android:textColorHint="#888888"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:imeOptions="actionDone" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:tint="#888888"
                    android:contentDescription="Toggle password visibility" />
            </LinearLayout>

            <!-- ═══════════ Login Button ═══════════ -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Đăng nhập"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_gradient"
                android:stateListAnimator="@null"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="20dp"
                android:letterSpacing="0.04"
                android:elevation="8dp" />

            <!-- ═══════════ Divider ═══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1AFFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  hoặc  "
                    android:textColor="#55FFFFFF"
                    android:textSize="13sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#1AFFFFFF" />
            </LinearLayout>

            <!-- ═══════════ Register Button ═══════════ -->
            <Button
                android:id="@+id/btn_go_register"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Tạo tài khoản mới"
                android:textSize="15sp"
                android:textColor="#C4B5FD"
                android:background="@drawable/bg_button_outline"
                android:stateListAnimator="@null"
                android:letterSpacing="0.02" />

            <!-- ═══════════ Skip Login ═══════════ -->
            <TextView
                android:id="@+id/tv_skip_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bỏ qua, đọc ngay →"
                android:textSize="13sp"
                android:textColor="#60FFFFFF"
                android:layout_marginTop="20dp"
                android:padding="8dp" />

        </LinearLayout>

    </FrameLayout>

</ScrollView>