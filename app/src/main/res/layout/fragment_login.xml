<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📚"
            android:textSize="64sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Truyện Hay"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chào mừng bạn trở lại!"
            android:textSize="14sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="40dp" />

        <!-- Error message -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#F44336"
            android:background="#FFF3F3"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Username -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Tên đăng nhập"
                    android:background="@android:color/transparent"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:maxLines="1" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Password -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:hint="Mật khẩu"
                    android:background="@android:color/transparent"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:maxLines="1" />

                <ImageButton
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:background="@android:color/transparent" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Nút đăng nhập -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Đăng nhập"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/light_divider" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  hoặc  " android:textColor="@color/light_text_secondary"
                android:textSize="13sp" />

            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/light_divider" />

        </LinearLayout>

        <!-- Nút đăng ký -->
        <Button
            android:id="@+id/btn_go_register"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Tạo tài khoản mới"
            android:textSize="15sp"
            android:textColor="@color/primary"
            android:backgroundTint="@color/light_surface" />

        <!-- Đọc không cần đăng nhập -->
        <TextView
            android:id="@+id/tv_skip_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bỏ qua, đọc ngay"
            android:textSize="13sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginTop="16dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

</ScrollView>
