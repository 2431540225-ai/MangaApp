<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A2E"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back_upload"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đăng truyện mới"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── THÔNG TIN TRUYỆN ─────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 Thông tin truyện"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_upload_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên truyện *"
                android:inputType="text"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_upload_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên tác giả *"
                android:inputType="text"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_upload_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mô tả truyện *"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_upload_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Thể loại (cách nhau bằng dấu phẩy, vd: Hành Động, Tình Cảm)"
                android:inputType="text"
                android:layout_marginBottom="12dp" />

            <!-- Ảnh bìa -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖼️ Ảnh bìa *"
                android:textSize="14sp"
                android:textColor="#444"
                android:layout_marginBottom="6dp" />

            <!-- Preview ảnh bìa -->
            <ImageView
                android:id="@+id/iv_cover_preview"
                android:layout_width="100dp"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/btn_pick_cover"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn ảnh bìa"
                    android:textSize="13sp"
                    android:backgroundTint="#1A1A2E"
                    android:textColor="@android:color/white" />

                <TextView
                    android:id="@+id/tv_cover_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chưa chọn ảnh"
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Loại truyện -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại truyện"
                android:textSize="14sp"
                android:textColor="#444"
                android:layout_marginBottom="4dp" />

            <RadioGroup
                android:id="@+id/rg_upload_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rb_upload_manga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Truyện tranh"
                    android:checked="true"
                    android:layout_marginEnd="24dp" />

                <RadioButton
                    android:id="@+id/rb_upload_novel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiểu thuyết" />
            </RadioGroup>

            <!-- ─── CHAPTER ĐẦU TIÊN ──────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄 Chapter đầu tiên"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_upload_chapter_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Số chương * (vd: 1)"
                android:inputType="number"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_upload_chapter_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tên chương (không bắt buộc)"
                android:inputType="text"
                android:layout_marginBottom="10dp" />

            <!-- Miễn phí / Trả phí -->
            <Switch
                android:id="@+id/switch_free_chapter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chương miễn phí"
                android:checked="true"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <!-- Giá coin (ẩn khi miễn phí) -->
            <LinearLayout
                android:id="@+id/layout_coin_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá (coin): "
                    android:textSize="14sp"
                    android:textColor="#444" />

                <EditText
                    android:id="@+id/et_coin_price"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:hint="vd: 5"
                    android:inputType="number"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 🪙"
                    android:textSize="16sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Ảnh trang (truyện tranh) -->
            <LinearLayout
                android:id="@+id/layout_page_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖼️ Ảnh các trang * (chọn nhiều cùng lúc)"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <Button
                        android:id="@+id/btn_pick_pages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn ảnh trang"
                        android:textSize="13sp"
                        android:backgroundTint="#1A1A2E"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:id="@+id/tv_pages_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chưa chọn ảnh"
                        android:textSize="12sp"
                        android:textColor="#888"
                        android:layout_marginStart="10dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Nội dung tiểu thuyết -->
            <LinearLayout
                android:id="@+id/layout_novel_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nội dung chương *:"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_novel_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập nội dung chương..."
                    android:inputType="textMultiLine"
                    android:minLines="8"
                    android:gravity="top"
                    android:layout_marginBottom="10dp" />
            </LinearLayout>

            <!-- Error message -->
            <TextView
                android:id="@+id/tv_upload_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E53935"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progress_upload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_progress_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#888"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Nút đăng -->
            <Button
                android:id="@+id/btn_upload_submit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Đăng truyện"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#1A1A2E"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
