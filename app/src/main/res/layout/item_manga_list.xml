<?xml version="1.0" encoding="utf-8"?>
<!-- Item dạng LIST (1 cột, ngang) -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/light_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <!-- Ảnh bìa -->
        <FrameLayout
            android:id="@+id/fl_cover"
            android:layout_width="80dp"
            android:layout_height="110dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:paddingHorizontal="5dp"
                android:paddingVertical="2dp"
                android:text="Đang ra"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:background="#CC4CAF50" />

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/fl_cover"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Tên truyện -->
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên truyện"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/light_text_primary"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Tác giả -->
            <TextView
                android:id="@+id/tv_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tác giả"
                android:textSize="12sp"
                android:textColor="@color/light_text_secondary"
                android:layout_marginTop="4dp" />

            <!-- Thể loại -->
            <TextView
                android:id="@+id/tv_genre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thể loại"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_views"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁 1,000"
                    android:textSize="12sp"
                    android:textColor="@color/light_text_secondary"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tv_chapters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 100 chương"
                    android:textSize="12sp"
                    android:textColor="@color/light_text_secondary" />

            </LinearLayout>

            <!-- Badge VIP -->
            <TextView
                android:id="@+id/tv_paid_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💎 Truyện VIP"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:background="@color/primary"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
