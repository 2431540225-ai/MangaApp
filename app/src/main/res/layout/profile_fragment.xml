<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen">

    <!-- TOOLBAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_profile"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:navigationIcon="@drawable/ic_nav_profile_book"
            app:navigationIconTint="@color/primary"
            app:title="Hồ sơ"
            app:titleCentered="true"
            app:titleTextColor="@color/primary_dark"
            app:menu="@menu/menu_profile_settings" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ==================== GUEST ==================== -->
            <LinearLayout
                android:id="@+id/layout_guest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:background="@drawable/bg_gradient_hero"
                android:visibility="visible">

                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_avatar_border"
                    android:layout_marginBottom="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤"
                        android:textSize="48sp"
                        android:layout_gravity="center" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng nhập để sử dụng đầy đủ tính năng"
                    android:textSize="16sp"
                    android:textColor="@color/primary_dark"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="24dp" />

                <Button
                    android:id="@+id/btn_login_profile"
                    android:layout_width="200dp"
                    android:layout_height="48dp"
                    android:text="Đăng nhập"
                    android:textSize="15sp"
                    android:background="@drawable/bg_button_gradient"
                    app:backgroundTint="@null"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>

            <!-- ==================== LOGGED IN ==================== -->
            <LinearLayout
                android:id="@+id/layout_logged_in"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- ===== HERO SECTION ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="20dp"
                    android:paddingBottom="24dp">

                    <!-- Avatar container: effect PNG behind + avatar on top -->
                    <FrameLayout
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:layout_gravity="center_horizontal">

                        <!-- avatar_effects.png as background layer, perfectly centred, fills the frame -->
                        <ImageView
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:src="@drawable/avatar_effects"
                            android:layout_gravity="center"
                            android:scaleType="fitXY"
                            android:contentDescription="" />

                        <!-- Avatar image centred on top of effects -->
                        <ImageView
                            android:id="@+id/img_avatar"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_menu_icon_circle"
                            android:scaleType="centerCrop" />

                    </FrameLayout>

                    <!-- Username -->
                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên người dùng"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                    <!-- Email -->
                    <TextView
                        android:id="@+id/tv_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="0dp" />

                </LinearLayout>

                <!-- ===== SCROLLABLE CONTENT ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="0dp">

                    <!-- Badge + Wallet Card overlap container -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp">

                        <!-- ===== WALLET CARD ===== -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            app:cardCornerRadius="16dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#D8C3FF"
                            app:cardElevation="10dp"
                            app:cardBackgroundColor="@android:color/transparent">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <!-- Card background -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_coin_card_premium"
                                    android:orientation="vertical" />


                                <!-- Card content -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingStart="20dp"
                                    android:paddingEnd="16dp"
                                    android:paddingTop="14dp"
                                    android:paddingBottom="14dp">

                                    <!-- Coin count + label -->
                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tv_coin_balance"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textSize="38sp"
                                            android:textStyle="bold"
                                            android:textColor="@color/primary" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Số dư ví"
                                            android:textSize="12sp"
                                            android:textColor="#6B7280"
                                            android:layout_marginTop="0dp" />
                                    </LinearLayout>

                                    <!-- Coin stack image — larger to match target -->
                                    <ImageView
                                        android:layout_width="80dp"
                                        android:layout_height="72dp"
                                        android:src="@drawable/coin_stack"
                                        android:scaleType="fitCenter"
                                        android:layout_marginStart="4dp"
                                        android:layout_marginEnd="0dp"
                                        android:contentDescription="" />

                                    <!-- Spacer -->
                                    <View
                                        android:layout_width="0dp"
                                        android:layout_height="1dp"
                                        android:layout_weight="1" />

                                    <!-- NAP COIN button -->
                                    <Button
                                        android:layout_width="wrap_content"
                                        android:layout_height="52dp"
                                        android:text="NẠP COIN ⚡"
                                        android:textSize="14sp"
                                        android:textColor="@color/white"
                                        android:textStyle="bold"
                                        android:letterSpacing="0.02"
                                        android:background="@drawable/bg_napcoin_button"
                                        app:backgroundTint="@null"
                                        android:insetTop="0dp"
                                        android:insetBottom="0dp"
                                        android:paddingHorizontal="20dp"
                                        style="@style/Widget.MaterialComponents.Button" />
                                </LinearLayout>
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Author badge pill — overlaps top border of card -->
                        <LinearLayout
                            android:id="@+id/layout_role_pill"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal|top"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingHorizontal="20dp"
                            android:elevation="12dp"
                            android:background="@drawable/bg_author_pill">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🪶"
                                android:textSize="14sp"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tv_role"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tác giả"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </FrameLayout>

                    <!-- ===== QUICK ACTIONS (3 cột ngang) ===== -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardCornerRadius="16dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E5E0FF"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <!-- Hàng ngang 3 ô weight=1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:orientation="horizontal">

                            <!-- Ô 1: Điểm danh -->
                            <LinearLayout
                                android:id="@+id/btn_daily_checkin"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <!-- Icon bg tròn -->
                                <FrameLayout
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_quick_tile"
                                    android:layout_marginBottom="4dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📅"
                                        android:textSize="20sp"
                                        android:layout_gravity="center" />
                                </FrameLayout>

                                <!-- Title -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Điểm danh"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#1F2937"
                                    android:gravity="center" />

                                <!-- Sub-label: streak hoặc "Nhận xu" -->
                                <TextView
                                    android:id="@+id/tv_checkin_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nhận xu!"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/white"
                                    android:background="@drawable/bg_badge_status"
                                    android:paddingHorizontal="6dp"
                                    android:paddingVertical="1dp"
                                    android:layout_marginTop="2dp"
                                    android:gravity="center" />
                            </LinearLayout>

                            <!-- Divider dọc giữa ô 1 và 2 -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center_vertical"
                                android:background="#E0E0E0" />

                            <!-- Ô 2: Ví coin -->
                            <LinearLayout
                                android:id="@+id/btn_wallet"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_quick_tile"
                                    android:layout_marginBottom="4dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="⭐"
                                        android:textSize="20sp"
                                        android:layout_gravity="center" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ví coin"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#1F2937"
                                    android:gravity="center" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="của tôi"
                                    android:textSize="10sp"
                                    android:textColor="#6B7280"
                                    android:gravity="center" />
                            </LinearLayout>

                            <!-- Divider dọc giữa ô 2 và 3 -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center_vertical"
                                android:background="#E0E0E0" />

                            <!-- Ô 3: Lịch sử đọc -->
                            <LinearLayout
                                android:id="@+id/btn_reading_history"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_quick_tile"
                                    android:layout_marginBottom="4dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="📖"
                                        android:textSize="20sp"
                                        android:layout_gravity="center" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Lịch sử"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#1F2937"
                                    android:gravity="center" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="đọc"
                                    android:textSize="10sp"
                                    android:textColor="#6B7280"
                                    android:gravity="center" />
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ===== AUTHOR SECTION ===== -->
                    <LinearLayout
                        android:id="@+id/layout_author_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="20dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E5E0FF"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingHorizontal="4dp"
                                android:paddingVertical="4dp">

                                <!-- Section header row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="52dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="16dp">

                                    <FrameLayout
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        android:background="@drawable/bg_menu_icon_circle"
                                        android:layout_marginEnd="12dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="✍️"
                                            android:textSize="16sp"
                                            android:layout_gravity="center" />
                                    </FrameLayout>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Khu vực tác giả"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="#1F2937" />
                                </LinearLayout>

                                <!-- Divider -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0.5dp"
                                    android:background="#1A000000"
                                    android:layout_marginHorizontal="16dp" />

                                <!-- Đăng truyện mới -->
                                <LinearLayout
                                    android:id="@+id/btn_upload_manga"
                                    android:layout_width="match_parent"
                                    android:layout_height="60dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="16dp"
                                    android:background="?attr/selectableItemBackground"
                                    android:clickable="true"
                                    android:focusable="true">

                                    <FrameLayout
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:background="@drawable/bg_menu_icon_circle"
                                        android:layout_marginEnd="14dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="➕"
                                            android:textSize="18sp"
                                            android:layout_gravity="center" />
                                    </FrameLayout>

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Đăng truyện mới"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="#1F2937" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="›"
                                        android:textSize="22sp"
                                        android:textColor="#9CA3AF" />
                                </LinearLayout>

                                <!-- Divider -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0.5dp"
                                    android:background="#1A000000"
                                    android:layout_marginHorizontal="16dp" />

                                <!-- Thêm chapter mới -->
                                <LinearLayout
                                    android:id="@+id/btn_add_chapter"
                                    android:layout_width="match_parent"
                                    android:layout_height="60dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="16dp"
                                    android:background="?attr/selectableItemBackground"
                                    android:clickable="true"
                                    android:focusable="true">

                                    <FrameLayout
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:background="@drawable/bg_napcoin_button"
                                        android:layout_marginEnd="14dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="➕"
                                            android:textSize="18sp"
                                            android:layout_gravity="center" />
                                    </FrameLayout>

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Thêm chapter mới"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="#1F2937" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="›"
                                        android:textSize="22sp"
                                        android:textColor="#9CA3AF" />
                                </LinearLayout>

                                <!-- Divider -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0.5dp"
                                    android:background="#1A000000"
                                    android:layout_marginHorizontal="16dp" />

                                <!-- Doanh thu -->
                                <LinearLayout
                                    android:id="@+id/btn_author_revenue"
                                    android:layout_width="match_parent"
                                    android:layout_height="60dp"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="16dp"
                                    android:background="?attr/selectableItemBackground"
                                    android:clickable="true"
                                    android:focusable="true">

                                    <FrameLayout
                                        android:layout_width="40dp"
                                        android:layout_height="40dp"
                                        android:background="@drawable/bg_menu_icon_circle"
                                        android:layout_marginEnd="14dp">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="💰"
                                            android:textSize="18sp"
                                            android:layout_gravity="center" />
                                    </FrameLayout>

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Doanh thu của tôi"
                                        android:textSize="14sp"
                                        android:textStyle="bold"
                                        android:textColor="#1F2937" />

                                    <TextView
                                        android:id="@+id/tv_author_pending"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text=""
                                        android:textSize="11sp"
                                        android:textColor="@color/white"
                                        android:textStyle="bold"
                                        android:background="@drawable/bg_badge_status"
                                        android:backgroundTint="@color/emerald"
                                        android:paddingHorizontal="8dp"
                                        android:paddingVertical="3dp"
                                        android:layout_marginEnd="8dp"
                                        android:visibility="gone" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="›"
                                        android:textSize="22sp"
                                        android:textColor="#9CA3AF" />
                                </LinearLayout>

                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- ===== LOGOUT BUTTON ===== -->
                    <Button
                        android:id="@+id/btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="← Đăng xuất"
                        android:textSize="14sp"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:background="@drawable/bg_logout_button"
                        app:backgroundTint="@null"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="32dp"
                        style="@style/Widget.MaterialComponents.Button" />

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>