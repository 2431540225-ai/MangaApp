<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/manga_card_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/light_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cover Image + Badge -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/manga_cover_height">

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <!-- Badge trạng thái -->
            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="@dimen/spacing_xs"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Đang ra"
                android:textColor="@color/white"
                android:textSize="@dimen/text_xs"
                android:textStyle="bold"
                android:background="#CC4CAF50"
                android:minWidth="0dp" />

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tv_manga_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên truyện"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:textColor="@color/light_text_primary"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_chapter_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100 chương"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/light_text_secondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
