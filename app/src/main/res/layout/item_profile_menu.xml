<?xml version="1.0" encoding="utf-8"?>
    <!--
        item_menu_row.xml
        Custom Layout tái sử dụng cho từng dòng menu trong Profile
        Dữ liệu đầu vào: menu_icon, menu_title, menu_subtitle (ẩn mặc định)
        Nơi sử dụng: ProfileFragment - phần Cài đặt
    -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon bên trái (dùng @android:drawable có sẵn) -->
    <ImageView
        android:id="@+id/menu_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_preferences"
        android:tint="#E94560"
        android:contentDescription="Menu icon" />

    <!-- Nhóm text: title + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/menu_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên mục"
            android:textSize="15sp"
            android:textColor="#1A1A2E" />

        <TextView
            android:id="@+id/menu_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#888888"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Mũi tên phải -->
    <ImageView
        android:id="@+id/menu_arrow"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@android:drawable/ic_media_next"
        android:tint="#CCCCCC"
        android:contentDescription="" />

</LinearLayout>