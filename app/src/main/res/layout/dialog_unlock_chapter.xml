<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Header icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="🔓"
        android:textSize="40sp"
        android:layout_marginBottom="8dp" />

    <!-- Tiêu đề -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Mở khóa chương"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="16dp" />

    <!-- Tên chapter -->
    <TextView
        android:id="@+id/tv_dialog_chapter_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chương 1: Khởi đầu"
        android:textSize="14sp"
        android:textColor="#444"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EBEBEB"
        android:layout_marginBottom="16dp" />

    <!-- Chi phí -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi phí mở khóa"
            android:textSize="14sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tv_dialog_coin_cost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 🪙"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F5A623" />
    </LinearLayout>

    <!-- Số coin hiện có -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ví của bạn"
            android:textSize="14sp"
            android:textColor="#666" />

        <TextView
            android:id="@+id/tv_dialog_current_coins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100 🪙"
            android:textSize="14sp"
            android:textColor="#444" />
    </LinearLayout>

    <!-- Cảnh báo không đủ coin (ẩn mặc định) -->
    <TextView
        android:id="@+id/tv_dialog_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Không đủ coin!"
        android:textSize="13sp"
        android:textColor="#E53935"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="12dp" />

    <!-- Progress bar (ẩn mặc định) -->
    <ProgressBar
        android:id="@+id/progress_dialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Nút xác nhận mở khóa -->
    <Button
        android:id="@+id/btn_dialog_unlock"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Xác nhận mở khóa"
        android:textSize="15sp"
        android:backgroundTint="#F5A623"
        android:textColor="@android:color/white"
        android:layout_marginBottom="8dp" />

    <!-- Nút mua coin (ẩn mặc định) -->
    <Button
        android:id="@+id/btn_dialog_buy_coins"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Nạp thêm coin"
        android:textSize="15sp"
        android:backgroundTint="#1A1A2E"
        android:textColor="@android:color/white"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Nút hủy -->
    <Button
        android:id="@+id/btn_dialog_cancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Hủy"
        android:textSize="15sp"
        android:backgroundTint="#EBEBEB"
        android:textColor="#444" />

</LinearLayout>