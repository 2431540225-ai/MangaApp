<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- HEADER -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="48dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="230dp"
                android:layout_height="130dp"
                android:src="@drawable/truyenhay_logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageButton
                android:id="@+id/btn_theme_toggle"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_dark_mode"
                android:contentDescription="Toggle Theme"
                app:tint="@color/color_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- HERO BANNER -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/banner_height"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingHorizontal="40dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false" />

        </FrameLayout>

        <!-- Dot Indicators -->
        <LinearLayout
            android:id="@+id/ll_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp" />

        <!-- MỚI CẬP NHẬT header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_latest_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mới Cập Nhật"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tv_latest_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem Tất Cả >"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:paddingVertical="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- RecyclerView Mới Cập Nhật (ngang) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_latest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp" />

        <!-- BẢNG XẾP HẠNG header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_ranking_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bảng Xếp Hạng"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tv_ranking_see_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem Tất Cả >"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:paddingVertical="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- RecyclerView Bảng Xếp Hạng (dọc) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ranking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="120dp"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>