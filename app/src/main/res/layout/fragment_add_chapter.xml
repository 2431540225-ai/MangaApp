<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A2E"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back_add_chapter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm chapter mới"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ─── CHỌN TRUYỆN ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 Chọn truyện"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="8dp" />

            <!-- Loading spinner cho danh sách truyện -->
            <ProgressBar
                android:id="@+id/progress_loading_stories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="visible" />

            <!-- Spinner chọn truyện -->
            <Spinner
                android:id="@+id/spinner_story"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@android:drawable/btn_dropdown"
                android:visibility="gone"
                android:layout_marginBottom="6dp" />

            <!-- Hiển thị thông tin truyện đã chọn -->
            <LinearLayout
                android:id="@+id/layout_selected_story_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:background="#F3F4F6"
                android:padding="10dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/iv_selected_story_cover"
                    android:layout_width="48dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:background="#DDDDDD"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_selected_story_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_selected_story_chapters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tv_selected_story_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#10B981"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:id="@+id/divider_chapter_section" />

            <!-- ─── THÔNG TIN CHAPTER ─────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layout_chapter_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄 Thông tin chapter"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/et_chapter_number"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Số chương * (vd: 2)"
                    android:inputType="number"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#9CA3AF"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/et_chapter_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên chương (không bắt buộc)"
                    android:inputType="text"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#9CA3AF"
                    android:layout_marginBottom="10dp" />

                <!-- Miễn phí / Trả phí -->
                <Switch
                    android:id="@+id/switch_free_chapter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chương miễn phí"
                    android:textColor="#1A1A2E"
                    android:checked="true"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <!-- Giá coin (ẩn khi miễn phí) -->
                <LinearLayout
                    android:id="@+id/layout_coin_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá (coin): "
                        android:textSize="14sp"
                        android:textColor="#1A1A2E" />

                    <EditText
                        android:id="@+id/et_coin_price"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:hint="vd: 5"
                        android:inputType="number"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 🪙"
                        android:textSize="16sp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <!-- ─── PHẦN ẢNH TRANG (Truyện tranh) ─────────────── -->
                <LinearLayout
                    android:id="@+id/layout_page_picker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼️ Ảnh các trang * (chọn nhiều cùng lúc)"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <Button
                            android:id="@+id/btn_pick_pages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn ảnh trang"
                            android:textSize="13sp"
                            android:backgroundTint="#1A1A2E"
                            android:textColor="@android:color/white" />

                        <TextView
                            android:id="@+id/tv_pages_status"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Chưa chọn ảnh"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginStart="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ─── PHẦN NỘI DUNG (Tiểu thuyết) ─────────────────── -->
                <LinearLayout
                    android:id="@+id/layout_novel_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nội dung chương *:"
                        android:textSize="13sp"
                        android:textColor="#1A1A2E"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_novel_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nhập nội dung chương..."
                        android:inputType="textMultiLine"
                        android:minLines="8"
                        android:gravity="top"
                        android:textColor="#1A1A2E"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginBottom="10dp" />
                </LinearLayout>

                <!-- Error -->
                <TextView
                    android:id="@+id/tv_add_chapter_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- Progress -->
                <ProgressBar
                    android:id="@+id/progress_add_chapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_progress_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <!-- Nút đăng chapter -->
                <Button
                    android:id="@+id/btn_submit_chapter"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Đăng chapter"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#1A1A2E"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
