<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/light_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <!-- Icon khóa (chỉ hiện với chapter trả phí chưa mở) -->
        <ImageView
            android:id="@+id/iv_lock_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_lock_lock"
            android:visibility="gone"
            android:tint="#F5A623"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Số chương -->
        <TextView
            android:id="@+id/tv_chapter_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chương 1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/light_text_primary"
            android:layout_marginStart="4dp"
            app:layout_constraintStart_toEndOf="@id/iv_lock_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Tên chương -->
        <TextView
            android:id="@+id/tv_chapter_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tên chương"
            android:textSize="13sp"
            android:textColor="@color/light_text_secondary"
            android:layout_marginTop="3dp"
            android:layout_marginStart="4dp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/iv_lock_icon"
            app:layout_constraintEnd_toStartOf="@id/tv_date"
            app:layout_constraintTop_toBottomOf="@id/tv_chapter_number" />

        <!-- Giá coin (hiện khi chapter bị khóa) -->
        <TextView
            android:id="@+id/tv_coin_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 🪙"
            android:textSize="12sp"
            android:textColor="#F5A623"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/tv_date"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Ngày đăng -->
        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/2026"
            android:textSize="12sp"
            android:textColor="@color/light_text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>