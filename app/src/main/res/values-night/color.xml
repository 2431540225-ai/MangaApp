    <color name="profile_bg">@color/dark_background</color>
    <color name="profile_text_muted">#99FFFFFF</color>
    <color name="profile_divider">#22FFFFFF</color>

    <!-- Profile adaptive cards (dark) -->
    <color name="color_profile_card_start">#1E1050</color>
    <color name="color_profile_card_end">#160D38</color>
    <color name="color_profile_tile_start">#160D38</color>
