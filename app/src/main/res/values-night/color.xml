    <color name="color_card">@color/dark_card</color>
    <color name="color_bottom_nav">@color/dark_bottom_nav</color>

    <!-- Text -->
    <color name="color_text_primary">@color/dark_text_primary</color>
    <color name="color_text_secondary">@color/dark_text_secondary</color>

    <!-- Icon & divider -->
    <color name="color_icon">@color/white</color>
