<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Generous pill radius for sleek badge look -->
    <corners android:radius="16dp" />
    <!-- 40% black fill — dark frosted glass effect -->
    <solid android:color="@color/glass_badge_bg" />
    <!-- 15% white hairline border — glassmorphism edge -->
    <stroke android:width="1dp" android:color="@color/glass_border" />
</shape>
