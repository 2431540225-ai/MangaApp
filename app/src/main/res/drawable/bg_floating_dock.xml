<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Large pill radius → true "floating dock" look -->
    <corners android:radius="36dp" />
    <!-- 80% opaque deep dark — glassmorphism surface -->
    <solid android:color="@color/dock_glass" />
    <!-- Ultra-thin 15%-white top border line -->
    <stroke android:width="1dp" android:color="@color/glass_border" />
</shape>
