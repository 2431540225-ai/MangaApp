<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!--
         Cinematic 3-stop gradient (top → bottom):
           0%   – fully transparent (top of image, no tint)
          50%   – 40% dark tint   (mid fade starts)
         100%   – 96% dark        (bottom, full text legibility)
    -->
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#00000000"
        android:centerColor="#660A0A0C"
        android:endColor="#F50A0A0C" />
</shape>
