<?xml version="1.0" encoding="utf-8"?>
<!-- Card chứa nút Tác giả + ví coin: tím đậm + viền tím nhạt -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#1E1245"
        android:centerColor="#251660"
        android:endColor="#1A1F4A"
        android:angle="135"
        android:type="linear" />
    <stroke
        android:width="1dp"
        android:color="#33A47CF3" />
    <corners android:radius="20dp" />
</shape>
